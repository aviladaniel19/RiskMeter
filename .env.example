# ═════════════════════════════════════════════════════════════════
# Configuración de Variables de Entorno - RISK METER DASHBOARD
# ═════════════════════════════════════════════════════════════════
# 
# Para desarrollo local:
#   1. Copia este archivo a .env
#   2. Rellena los valores
#   3. El archivo .env será ignorado por git (está en .gitignore)
#
# Para producción (Vercel):
#   Configura estas variables en: Settings → Environment Variables
# ═════════════════════════════════════════════════════════════════

# ── BASE DE DATOS ──────────────────────────────────────────────
# Para DESARROLLO (SQLite - ya configurado):
# DATABASE_URL=sqlite:///./risklab.db

# Para PRODUCCIÓN (Supabase PostgreSQL):
# Obtén esta URL en: Supabase Dashboard → Settings → Database → URI
DATABASE_URL=postgresql://[USER]:[PASSWORD]@[HOST]/[DATABASE]

# ── APIs FINANCIERAS EXTERNAS ──────────────────────────────────
# FRED API (datos macroeconómicos)
# Obtén la clave en: https://fred.stlouisfed.org/docs/api/fred/
FRED_API_KEY=tu_clave_fred_aqui

# Alpha Vantage API (precios históricos)
# Obtén la clave en: https://www.alphavantage.co/api/
ALPHA_VANTAGE_KEY=

# Finnhub API (datos financieros)
# Obtén la clave en: https://finnhub.io/
FINNHUB_KEY=

# ── PARÁMETROS DE RIESGO ───────────────────────────────────────
# Nivel de confianza para VaR (95% o 99%)
VAR_CONFIDENCE_DEFAULT=0.95

# Número de simulaciones Monte Carlo
MONTECARLO_N_SIM=10000

# Ventana histórica (días de trading)
GARCH_WINDOW=252

# Ticker del índice de referencia (benchmark)
BENCHMARK_TICKER=^GSPC

# ── SERIE FRED PARA TASA LIBRE DE RIESGO ──────────────────────
# T-Bill 3 meses (DGS3MO) o 10 años (DGS10)
FRED_RF_SERIE=DGS3MO

# ── SERVIDOR ───────────────────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# ── CORS (Control de acceso desde otros dominios) ──────────────
# Para desarrollo: ["*"]
# Para producción: ["https://tudominio.com", "https://www.tudominio.com"]
CORS_ORIGINS=["*"]

# ── ENTORNO ────────────────────────────────────────────────────
# development, staging, production
ENVIRONMENT=development
